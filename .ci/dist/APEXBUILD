pkgname=com.shadichy.makeapex
pkgver=1.0.0
pkgrel=1
arch=('any')
payload_fs=erofs
source=("git+http://10.249.0.1/android-generic/makeapex.git")

build() {
  echo "Building makeapex APEX..."
}

package() {
  mkdir -p "$pkgdir/bin"
  mkdir -p "$pkgdir/lib/libmakeapex"
  
  # Copy scripts
  cp "$srcdir/makeapex/makeapex.sh" "$pkgdir/bin/makeapex"
  cp -r "$srcdir/makeapex/libmakeapex"/* "$pkgdir/lib/libmakeapex/"
  cp "$srcdir/makeapex/makeapex.conf" "$pkgdir/"
  if [ -f "$srcdir/makeapex/avbtool" ]; then
      cp "$srcdir/makeapex/avbtool" "$pkgdir/"
  fi
  
  # Ensure executables
  chmod +x "$pkgdir/bin/makeapex"
  if [ -f "$pkgdir/avbtool" ]; then
      chmod +x "$pkgdir/avbtool"
  fi
}
