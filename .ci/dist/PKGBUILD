pkgname=makeapex
pkgver=1.0.0
pkgrel=1
pkgdesc="Autonomous Android APEX build system modeled after makepkg"
arch=('any')
url="https://github.com/shadichy/makeapex"
license=('GPL')
depends=('android-tools' 'bash' 'coreutils' 'awk' 'sed' 'e2fsprogs' 'erofs-utils' 'zip' 'unzip' 'openssl' 'python' 'binutils' 'gcc')
source=("git+http://10.249.0.1:3002/android-generic/makeapex.git")
md5sums=('SKIP')

package() {
  # Create directories
  install -d "$pkgdir/opt/makeapex"
  install -d "$pkgdir/usr/bin"
  
  # Copy files
  cp -r "$srcdir/makeapex/src/"* "$pkgdir/opt/makeapex/"
  
  # Ensure makeapex script is executable
  chmod +x "$pkgdir/opt/makeapex/makeapex.sh"
  
  # Create symlink
  ln -s /opt/makeapex/makeapex.sh "$pkgdir/usr/bin/makeapex"
}
