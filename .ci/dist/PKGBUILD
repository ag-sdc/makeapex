pkgname=makeapex
pkgver=1.0.0
pkgrel=1
pkgdesc="Autonomous Android APEX build system modeled after makepkg"
arch=('any')
url="https://github.com/shadichy/makeapex"
license=('GPL')
depends=('android-tools' 'bash' 'coreutils' 'awk' 'sed' 'e2fsprogs' 'erofs-utils' 'zip' 'unzip' 'openssl' 'python' 'binutils' 'gcc')
source=("makeapex::git+file://${startdir}/../../")
md5sums=('SKIP')

package() {
  cd "$srcdir/makeapex/src"
  make DESTDIR="$pkgdir" PREFIX=/usr install
}
