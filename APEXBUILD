pkgname=com.shadichy.makeapex
pkgver=1.0.0
pkgrel=1
arch=('any')
payload_fs=erofs


build() {
  echo "Building makeapex APEX..."
}

package() {
  mkdir -p "$pkgdir/bin"
  mkdir -p "$pkgdir/lib/libmakeapex"
  
  # Copy scripts
  cp src/makeapex.sh "$pkgdir/bin/makeapex"
  cp -r src/libmakeapex/* "$pkgdir/lib/libmakeapex/"
  cp src/makeapex.conf "$pkgdir/"
  if [ -f "src/avbtool" ]; then
      cp src/avbtool "$pkgdir/"
  fi
  
  # Ensure executables
  chmod +x "$pkgdir/bin/makeapex"
  if [ -f "$pkgdir/avbtool" ]; then
      chmod +x "$pkgdir/avbtool"
  fi
}
