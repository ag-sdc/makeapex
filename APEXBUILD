pkgname=com.shadichy.makeapex
pkgver=1.0.0
pkgrel=1
arch=('any')
payload_fs=erofs

build() {
  echo "Building makeapex APEX..."
}

package() {
  mkdir -p "$pkgdir/vendor/bin"
  mkdir -p "$pkgdir/vendor/libmakeapex"
  
  # Copy scripts
  cp makeapex.sh "$pkgdir/vendor/bin/makeapex"
  cp -r libmakeapex/* "$pkgdir/vendor/libmakeapex/"
  cp makeapex.conf "$pkgdir/vendor/"
  if [ -f "avbtool" ]; then
      cp avbtool "$pkgdir/vendor/"
  fi
  
  # Ensure executables
  chmod +x "$pkgdir/vendor/bin/makeapex"
  if [ -f "$pkgdir/vendor/avbtool" ]; then
      chmod +x "$pkgdir/vendor/avbtool"
  fi
}
