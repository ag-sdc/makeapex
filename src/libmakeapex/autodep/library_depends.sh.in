[[ -n "$LIBMAKEAPEX_AUTODEP_LIBRARY_DEPENDS_SH" ]] && return
LIBMAKEAPEX_AUTODEP_LIBRARY_DEPENDS_SH=1

MAKEAPEX_LIBRARY=${MAKEAPEX_LIBRARY:-"@libmakeapexdir@"}

autodep_functions+=('library_depends')

library_depends() {
	if [[ $vndk == "static" ]]; then
		return 0
	fi

	local filename sofile
	declare -A libdeps
	declare -a process_queue

	# Find all ELF files currently in pkgdir and queue their dependencies
	while IFS= read -rd '' filename; do
		while IFS= read -r sofile; do
			if [[ -z $sofile ]]; then continue; fi
			if [[ -z ${libdeps["$sofile"]} ]]; then
				libdeps["$sofile"]=1
				process_queue+=("$sofile")
			fi
		done < <(LC_ALL=C readelf -d "$filename" 2>/dev/null | sed -nr 's/.*Shared library: \[(.*)\].*/\1/p')
	done < <(find "$pkgdir" -type f \( -perm -u+x -o -name "*.so" -o -name "*.so.*" \) -print0)

	local BIONIC_LIBS=(libc.so libm.so libdl.so libdl_android.so)

	# Process queue (allows for recursive dependency tracking if we bundle new .so files)
	local i=0
	while [[ $i -lt ${#process_queue[@]} ]]; do
		sofile="${process_queue[$i]}"
		i=$((i+1))

		# Skip if provided inside the APEX itself
		if [[ -e "$pkgdir/lib/$sofile" || -e "$pkgdir/lib64/$sofile" ]]; then
			continue
		fi

		local is_bionic=0
		for b in "${BIONIC_LIBS[@]}"; do
			if [[ $sofile == "$b" ]]; then
				is_bionic=1
				break
			fi
		done

		if [[ $vndk == "bundled" && $is_bionic -eq 0 ]]; then
			local found=0
			local vndk_root="${VNDK_DIR:-$ANDROID_HOME/vndk}"
			local local_path
			local_path=$(find "$vndk_root" -name "$sofile" 2>/dev/null | head -n 1)

			local target_dir="$pkgdir/lib"
			mkdir -p "$target_dir"

			if [[ -n $local_path ]]; then
				msg2 "$(gettext "Bundling local VNDK library %s")" "$sofile"
				cp "$local_path" "$target_dir/$sofile"
				found=1
			fi

			if [[ $found -eq 0 ]]; then
				error "$(gettext "Cannot find or fetch library %s to bundle for vndk=bundled")" "$sofile"
				exit 1
			fi

			# Recursively process the newly bundled library for its dependencies
			while IFS= read -r new_so; do
				if [[ -n $new_so && -z ${libdeps["$new_so"]} ]]; then
					libdeps["$new_so"]=1
					process_queue+=("$new_so")
				fi
			done < <(LC_ALL=C readelf -d "$target_dir/$sofile" 2>/dev/null | sed -nr 's/.*Shared library: \[(.*)\].*/\1/p')

		else
			# Not bundled (off, shared, or it's a bionic library)
			echo "$sofile" >> "$pkgdirbase/.requireNativeLibs"
		fi
	done

	# Remove duplicates in .requireNativeLibs if created
	if [[ -f "$pkgdirbase/.requireNativeLibs" ]]; then
		sort -u -o "$pkgdirbase/.requireNativeLibs" "$pkgdirbase/.requireNativeLibs"
	fi
}
