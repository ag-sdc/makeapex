[[ -n "$LIBMAKEAPEX_LINT_APEXBUILD_CHANGELOG_SH" ]] && return
LIBMAKEAPEX_LINT_APEXBUILD_CHANGELOG_SH=1

MAKEAPEX_LIBRARY=${MAKEAPEX_LIBRARY:-"@libmakeapexdir@"}

source "$MAKEAPEX_LIBRARY/util/message.sh"
source "$MAKEAPEX_LIBRARY/util/apexbuild.sh"
source "$MAKEAPEX_LIBRARY/lint_apexbuild/util.sh"


lint_apexbuild_functions+=('lint_changelog')


lint_changelog() {
	local file changelog_list

	changelog_list=("${changelog[@]}")
	# set pkgname the same way we do for running package(), this way we get
	# the right value in extract_function_variable
	# shellcheck disable=SC2206
	local pkgname_backup=(${pkgname[@]})
	local pkgname
	for pkgname in "${pkgname_backup[@]}"; do
		if extract_function_variable "package_$pkgname" changelog 0 file; then
			changelog_list+=("$file")
		fi
	done

	check_files_exist 'changelog' "${changelog_list[@]}" || ret=1

	return "$ret"
}
