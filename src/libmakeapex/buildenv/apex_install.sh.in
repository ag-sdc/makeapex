#!/bin/bash
# shellcheck disable=SC2154,SC2034,SC1090

[[ -n "$LIBMAKEAPEX_BUILDENV_APEX_INSTALL_SH" ]] && return
LIBMAKEAPEX_BUILDENV_APEX_INSTALL_SH=1

buildenv_apex_install() {
	if type -p apexm >/dev/null; then
		for dep in "${makedepends[@]}"; do
			local apex_name
			apex_name=$(${PACMAN_AUTH[@]} apexm local --name "$dep" 2>/dev/null)
			if [[ -n "$apex_name" ]]; then
				export CFLAGS="$CFLAGS -I/apex/$apex_name/include"
				export CXXFLAGS="$CXXFLAGS -I/apex/$apex_name/include"
				export LDFLAGS="$LDFLAGS -L/apex/$apex_name/lib"
				export PKG_CONFIG_PATH="/apex/$apex_name/lib/pkgconfig${PKG_CONFIG_PATH:+:}$PKG_CONFIG_PATH"
			fi
		done
	fi
}

buildenv_functions+=('buildenv_apex_install')
