[[ -n "$LIBMAKEAPEX_LINT_APEXBUILD_SH" ]] && return
LIBMAKEAPEX_LINT_APEXBUILD_SH=1

MAKEAPEX_LIBRARY=${MAKEAPEX_LIBRARY:-"@libmakeapexdir@"}

source "$MAKEAPEX_LIBRARY/util/message.sh"


declare -a lint_apexbuild_functions

for lib in "$MAKEAPEX_LIBRARY/lint_apexbuild/"*.sh; do
	source "$lib"
done

readonly -a lint_apexbuild_functions


lint_apexbuild() {
	local ret=0

	# shellcheck disable=SC2068
	for func in "${lint_apexbuild_functions[@]}"; do
		$func || ret=1
	done

	return $ret
}
