#!/bin/bash
# shellcheck disable=SC1091,SC2154,SC2034,SC1090
#
#   linkerconfig.sh - Generate Android linker.config.json and apex_manifest.json deps
#

[[ -n "$LIBMAKEAPEX_TIDY_LINKERCONFIG_SH" ]] && return
LIBMAKEAPEX_TIDY_LINKERCONFIG_SH=1

MAKEAPEX_LIBRARY=${MAKEAPEX_LIBRARY:-"@libmakeapexdir@"}

source "$MAKEAPEX_LIBRARY/util/message.sh"
source "$MAKEAPEX_LIBRARY/util/apexbuild.sh"

tidy_modify+=('tidy_linkerconfig')

get_dummy_suffixes() {
	dummy_suffixes=("")
	if [[ " ${arch[*]} " =~ " x86_64 " ]] || [[ "$CARCH" == "x86_64" ]]; then
		local lvl=${_x86_64_microarch_level:-2}
		local i
		for ((i = 2; i <= lvl; i++)); do
			dummy_suffixes+=("-x86_64-v${i}")
		done
	elif [[ " ${arch[*]} " =~ " aarch64 " ]] || [[ "$CARCH" == "aarch64" ]]; then
		local lvl=${_aarch64_microarch_level:-8.2}
		local current="8.1"
		while awk -v c="$current" -v max="$lvl" 'BEGIN { exit !(c <= max) }'; do
			dummy_suffixes+=("-aarch64-v${current//./_}")
			current=$(awk -v c="$current" 'BEGIN { printf "%.1f", c + 0.1 }')
		done
	fi
}

gen_libdummy() {
	local base_name="$1"
	local dummy_name="libdummy${base_name}.so"
	prov_libs+=("$dummy_name")
	ln -s "$dummy_lib_name" "$pkgdirprefix/lib/$dummy_name"
}

parse_depends() {
	for d in "${depends[@]}"; do
		if [[ "$d" == *.so* ]]; then
			req_libs+=("$d")
		elif [[ "$d" == _* ]]; then
			if [[ "$d" =~ ^_(.+)-([^-]+)-([^-]+)$ ]]; then
				local soname="${BASH_REMATCH[1]}"
				local d_arch="${BASH_REMATCH[2]}"
				local d_march="${BASH_REMATCH[3]}"
				req_libs+=("libdummy-${soname//_/-}-${d_arch}-${d_march}.so")
			else
				req_libs+=("libdummy${d//_/-}.so")
			fi
		fi
	done
}

parse_dump_object() {
	while IFS= read -rd '' binary; do
		if ! LC_ALL=C readelf -h "$binary" 2>/dev/null | grep -q 'ELF'; then
			continue
		fi

		local soname
		soname=$(LC_ALL=C readelf -d "$binary" 2>/dev/null | grep 'SONAME' | sed -E 's/.*\[([^]]+)\].*/\1/')
		if [[ -n "$soname" ]]; then
			prov_libs+=("$soname")
		else
			local bin_name
			bin_name=$(basename "$binary")
			gen_libdummy "_binary_${bin_name//_/-}"
		fi

		while IFS= read -r n; do
			if [[ -n "$n" ]]; then
				req_libs+=("$n")
			fi
		done < <(LC_ALL=C readelf -d "$binary" 2>/dev/null | grep 'NEEDED' | sed -E 's/.*\[([^]]+)\].*/\1/')
	done < <(find "$pkgdirprefix" -type f -perm -u+w -print0 2>/dev/null)

	while IFS= read -rd '' symlink; do
		local symlink_name
		symlink_name=$(basename "$symlink")
		if [[ "$symlink_name" == *.so* ]]; then
			prov_libs+=("$symlink_name")
		fi
	done < <(find "$pkgdirprefix" -type l -print0 2>/dev/null)
}

parse_shared_res() {
	local share_dir="$pkgdirprefix/share"
	if [[ ! -d "$share_dir" ]]; then
		return
	fi

	for resource_path in "$share_dir"/*; do
		if [[ ! -d "$resource_path" ]]; then
			continue
		fi

		local resource_name
		resource_name=$(basename "$resource_path")

		local skip=1
		case "$resource_name" in
		icon*)
			if [[ "$pkgname" == *icon* ]] || [[ "$pkgbase" == *icon* ]]; then skip=0; fi
			;;
		theme*)
			if [[ "$pkgname" == *theme* ]] || [[ "$pkgbase" == *theme* ]]; then skip=0; fi
			;;
		zoneinfo)
			if [[ "$pkgname" == "tzdata" ]] || [[ "$pkgbase" == "tzdata" ]]; then skip=0; fi
			;;
		terminfo)
			if [[ "$pkgname" =~ ^(lib)?ncursesw?$ ]] || [[ "$pkgbase" =~ ^(lib)?ncursesw?$ ]]; then skip=0; fi
			;;
		doc | man | info | background* | wallpaper* | locale | applications | mime | licenses | pkgconfig | aclocal | zsh | bash-completion)
			skip=1
			;;
		*)
			skip=0
			;;
		esac

		if [[ $skip -eq 1 ]]; then
			continue
		fi

		gen_libdummy "_shared_${resource_name//_/-}"
	done
}

gen_provides() {
	for p in "${provides[@]}"; do
		if [[ "$p" == *.so* ]]; then
			prov_libs+=("$p")
		elif [[ "$p" == _* ]]; then
			gen_libdummy "${p//_/-}"
		fi
	done
}

gen_march_symlinks() {
	local current_prov=("${prov_libs[@]}")
	for p in "${current_prov[@]}"; do
		if [[ "$p" == *.so* ]]; then
			local link_dir="$pkgdirprefix/lib"
			mkdir -p "$link_dir"
			local is_suffixed=0
			for sfx in "${dummy_suffixes[@]}"; do
				if [[ -n "$sfx" ]] && [[ "$p" == *"$sfx.so"* ]]; then
					is_suffixed=1
					break
				fi
			done

			if [[ $is_suffixed -eq 0 ]]; then
				for sfx in "${dummy_suffixes[@]}"; do
					if [[ -z "$sfx" ]]; then continue; fi
					local sfx_name="${p/.so/$sfx.so}"
					ln -sf "$p" "$link_dir/$sfx_name"
					prov_libs+=("$sfx_name")
				done
			fi
		fi
	done
}

write_linker_config() {
	local unique_req=()
	local unique_prov=()

	if [ ${#prov_libs[@]} -gt 0 ]; then
		while IFS= read -r line; do
			unique_prov+=("$line")
		done < <(printf "%s\n" "${prov_libs[@]}" | sort -u)
	fi

	if [ ${#req_libs[@]} -gt 0 ]; then
		while IFS= read -r line; do
			local found=0
			for p in "${unique_prov[@]}"; do
				if [[ "$line" == "$p" ]]; then
					found=1
					break
				fi
			done
			if [[ $found -eq 0 ]]; then
				unique_req+=("$line")
			fi
		done < <(printf "%s\n" "${req_libs[@]}" | sort -u)
	fi

	mkdir -p "$pkgdirprefix/etc"
	local linker_config="$pkgdirprefix/etc/linker.config.json"

	{
		echo "{"
		{
			if [ ${#unique_prov[@]} -gt 0 ]; then
				echo "\"provideLibs\": ["
				{
					local i=0
					for p in "${unique_prov[@]}"; do
						if [[ $i -gt 0 ]]; then echo ","; else echo ""; fi
						echo -n "    \"$p\""
						i=$((i + 1))
					done
					if [[ $i -gt 0 ]]; then echo ""; fi
				} | add_tab
				echo -n "]"
				if [ ${#unique_req[@]} -gt 0 ]; then
					echo ","
				fi
			fi
			if [ ${#unique_req[@]} -gt 0 ]; then
				echo "\"requireLibs\": ["
				{
					i=0
					for r in "${unique_req[@]}"; do
						if [[ $i -gt 0 ]]; then echo ","; else echo ""; fi
						echo -n "    \"$r\""
						i=$((i + 1))
					done
					if [[ $i -gt 0 ]]; then echo ""; fi
				} | add_tab
				echo -n "]"
			fi
			echo ","
			echo "\"visible\": true"
		} | add_tab
		echo "}"
	} >"$linker_config"

	write_native_libs
}

write_native_libs() {
	rm -f "$pkgnamedir/.provideNativeLibs" "$pkgnamedir/.requireNativeLibs"
	if [ ${#unique_prov[@]} -gt 0 ]; then
		printf "%s\n" "${unique_prov[@]}" >"$pkgnamedir/.provideNativeLibs"
	fi
	if [ ${#unique_req[@]} -gt 0 ]; then
		printf "%s\n" "${unique_req[@]}" >"$pkgnamedir/.requireNativeLibs"
	fi
}

tidy_linkerconfig() {
	msg2 "$(gettext "Generating APEX linker configuration and dependencies...")"

	local req_libs=()
	local prov_libs=()
	local dummy_suffixes=()
	local dummy_lib_name=_libdummy.so
	mkdir -p "$pkgdirprefix/lib"

	parse_depends
	parse_dump_object
	parse_shared_res
	gen_provides

	get_dummy_suffixes
	gen_march_symlinks

	local dummy_lib="$pkgdirprefix/lib/$dummy_lib_name"
	if [[ ! -f "$dummy_lib" ]]; then
		echo 'void dummy(void){}' | ${CC:-gcc} -shared -xc - -o "$dummy_lib"
	fi

	write_linker_config
}
