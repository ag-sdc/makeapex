#!/bin/bash
# shellcheck disable=SC1091,SC2154,SC2034,SC1090
#
#   linkerconfig.sh - Generate Android linker.config.json and apex_manifest.json deps
#

[[ -n "$LIBMAKEAPEX_TIDY_LINKERCONFIG_SH" ]] && return
LIBMAKEAPEX_TIDY_LINKERCONFIG_SH=1

MAKEAPEX_LIBRARY=${MAKEAPEX_LIBRARY:-"@libmakeapexdir@"}

source "$MAKEAPEX_LIBRARY/util/message.sh"
source "$MAKEAPEX_LIBRARY/util/apexbuild.sh"

tidy_modify+=('tidy_linkerconfig')

get_dummy_suffixes() {
	dummy_suffixes=("")
	local lvl
	for lvl in $(microarch_from_lowest); do
		dummy_suffixes+=("-${pkgarch}-v${lvl//./_}")
	done
}

gen_libdummy() {
	local base_name="$1"
	local dummy_name="libdummy${base_name}.so"
	prov_libs+=("$dummy_name")
	ln -s "$dummy_lib_name" "$pkgdirprefix/lib/$dummy_name"
}

parse_depends() {
	for d in "${depends[@]}"; do
		if [[ "$d" == *.so* ]]; then
			req_libs+=("$d")
		elif [[ "$d" == _* ]]; then
			if [[ "$d" =~ ^_(.+)-([^-]+)-([^-]+)$ ]]; then
				local soname="${BASH_REMATCH[1]}"
				local d_arch="${BASH_REMATCH[2]}"
				local d_march="${BASH_REMATCH[3]}"
				req_libs+=("libdummy-${soname//_/-}-${d_arch}-${d_march}.so")
			else
				req_libs+=("libdummy${d//_/-}.so")
			fi
		fi
	done
}

parse_dump_object() {
	while IFS= read -rd '' binary; do
		if ! LC_ALL=C readelf -h "$binary" 2>/dev/null | grep -q 'ELF'; then
			continue
		fi

		local soname
		soname=$(LC_ALL=C readelf -d "$binary" 2>/dev/null | grep 'SONAME' | sed -E 's/.*\[([^]]+)\].*/\1/')
		if [[ -n "$soname" ]]; then
			prov_libs+=("$soname")
		else
			local bin_name
			bin_name=$(basename "$binary")
			gen_libdummy "_binary_${bin_name//_/-}"
		fi

		while IFS= read -r n; do
			if [[ -z "$n" ]]; then
				continue
			fi

			local local_lib
			local_lib=$(find "$pkgdirprefix"/lib{,64} -type f -name "$d" -print0 2>/dev/null)
			if [[ -z "$local_lib" ]]; then
				req_libs+=("$d")
			fi
		done < <(LC_ALL=C readelf -d "$binary" 2>/dev/null | grep 'NEEDED' | sed -E 's/.*\[([^]]+)\].*/\1/')
	done < <(find "$pkgdirprefix"/{bin,lib{,64}} -type f -perm -u+w -print0 2>/dev/null)

	while IFS= read -rd '' symlink; do
		local symlink_name
		symlink_name=$(basename "$symlink")
		if [[ "$symlink_name" == *.so* ]]; then
			prov_libs+=("$symlink_name")
		fi
	done < <(find "$pkgdirprefix"/{bin,lib{,64}} -type l -print0 2>/dev/null)
}

parse_shared_res() {
	local share_dir="$pkgdirprefix/share"
	if [[ ! -d "$share_dir" ]]; then
		return
	fi

	for resource_path in "$share_dir"/*; do
		if [[ ! -d "$resource_path" ]]; then
			continue
		fi

		local resource_name
		resource_name=$(basename "$resource_path")

		local skip=1
		case "$resource_name" in
		icon*) if [[ "$package_name" == *icon* ]]; then skip=0; fi ;;
		theme*) if [[ "$package_name" == *theme* ]]; then skip=0; fi ;;
		zoneinfo) if [[ "$package_name" == "tzdata" ]]; then skip=0; fi ;;
		terminfo) if [[ "$package_name" =~ ^(lib)?ncursesw?$ ]]; then skip=0; fi ;;
		doc | man | info | background* | wallpaper* | locale | applications | mime | licenses | pkgconfig | aclocal | zsh | bash-completion) skip=1 ;;
		*) skip=0 ;;
		esac

		if [[ $skip -eq 1 ]]; then
			continue
		fi

		gen_libdummy "_shared_${resource_name//_/-}"
	done
}

gen_provides() {
	for p in "${provides[@]}"; do
		if [[ "$p" == *.so* ]]; then
			prov_libs+=("$p")
		elif [[ "$p" == _* ]]; then
			gen_libdummy "${p//_/-}"
		fi
	done

	gen_libdummy "_${package_name//-/_}"

	# Development headers and pkgconfig files
	if [[ -d "$pkgdirprefix/include" ]]; then
		local package_base=${pkgbase:-$package_name}
		gen_libdummy "_headers_${package_base//-/_}"
		if [[ -d "$pkgdirprefix/lib/pkgconfig" ]]; then
			gen_libdummy "_pkgconfig_${package_base//-/_}"
		fi
	fi

	# Kernel modules
	find "$pkgdirprefix/lib{,64}/modules" -mindepth 2 -maxdepth 2 -type f -name "vmlinu[xz]" -print0 2>/dev/null | while IFS= read -rd '' kernel; do
		local kver
		kver=$(basename "$(dirname "$kernel")")
		gen_libdummy "_linux_${kver}" # Preserve kernel version
		if [[ -d "$pkgdirprefix/lib/modules/${kver}/build" ]]; then
			gen_libdummy "_linuxheaders_${kver}" # Preserve kernel version
		fi
	done

	# Firmwares
	find "$pkgdirprefix/lib{,64}/firmware" -mindepth 1 -maxdepth 1 -print0 2>/dev/null | while IFS= read -rd '' firmware; do
		local fw_name
		fw_name=$(basename "$firmware")
		if [[ -f "$firmware" ]] && file "$firmware" | grep -Iq 'compressed'; then
			fw_name="${fw_name%.*}"
		fi
		gen_libdummy "_firmware_${fw_name}" # Preserve firmware names
	done
}

gen_march_symlinks() {
	local current_prov=("${prov_libs[@]}")
	for p in "${current_prov[@]}"; do
		if [[ "$p" == *.so* ]]; then
			local link_dir="$pkgdirprefix/lib"
			mkdir -p "$link_dir"
			local is_suffixed=0
			for sfx in "${dummy_suffixes[@]}"; do
				if [[ -n "$sfx" ]] && [[ "$p" == *"$sfx.so"* ]]; then
					is_suffixed=1
					break
				fi
			done

			if [[ $is_suffixed -eq 0 ]]; then
				for sfx in "${dummy_suffixes[@]}"; do
					if [[ -z "$sfx" ]]; then continue; fi
					local sfx_name="${p/.so/$sfx.so}"
					ln -sf "$p" "$link_dir/$sfx_name"
					prov_libs+=("$sfx_name")
				done
			fi
		fi
	done
}

write_linker_config() {
	local unique_req=()
	local unique_prov=()

	if [ ${#prov_libs[@]} -gt 0 ]; then
		while IFS= read -r line; do
			unique_prov+=("$line")
		done < <(printf "%s\n" "${prov_libs[@]}" | sort -u)
	fi

	if [ ${#req_libs[@]} -gt 0 ]; then
		while IFS= read -r line; do
			local found=0
			for p in "${unique_prov[@]}"; do
				if [[ "$line" == "$p" ]]; then
					found=1
					break
				fi
			done
			if [[ $found -eq 0 ]]; then
				unique_req+=("$line")
			fi
		done < <(printf "%s\n" "${req_libs[@]}" | sort -u)
	fi

	mkdir -p "$pkgdirprefix/etc"
	local linker_config="$pkgdirprefix/etc/linker.config.json"

	{
		echo "{"
		{
			if [ ${#unique_prov[@]} -gt 0 ]; then
				echo -n "\"provideLibs\": ["
				{
					local i=0
					for p in "${unique_prov[@]}"; do
						if [[ $i -gt 0 ]]; then echo ","; else echo ""; fi
						echo -n "    \"$p\""
						i=$((i + 1))
					done
					if [[ $i -gt 0 ]]; then echo ""; fi
				} | add_tab
				echo -n "]"
				if [ ${#unique_req[@]} -gt 0 ]; then
					echo ","
				fi
			fi
			if [ ${#unique_req[@]} -gt 0 ]; then
				echo -n "\"requireLibs\": ["
				{
					i=0
					for r in "${unique_req[@]}"; do
						if [[ $i -gt 0 ]]; then echo ","; else echo ""; fi
						echo -n "    \"$r\""
						i=$((i + 1))
					done
					if [[ $i -gt 0 ]]; then echo ""; fi
				} | add_tab
				echo -n "]"
			fi
			echo ","
			echo "\"visible\": true"
		} | add_tab
		echo "}"
	} >"$linker_config"

	write_native_libs
}

write_native_libs() {
	rm -f "$pkgnamedir/.provideNativeLibs" "$pkgnamedir/.requireNativeLibs"
	if [ ${#unique_prov[@]} -gt 0 ]; then
		printf "%s\n" "${unique_prov[@]}" >"$pkgnamedir/.provideNativeLibs"
	fi
	if [ ${#unique_req[@]} -gt 0 ]; then
		printf "%s\n" "${unique_req[@]}" >"$pkgnamedir/.requireNativeLibs"
	fi
}

tidy_linkerconfig() {
	msg2 "$(gettext "Generating APEX linker configuration and dependencies...")"

	local req_libs=()
	local prov_libs=()
	local dummy_suffixes=()
	local dummy_lib_name=_libdummy.so
	mkdir -p "$pkgdirprefix/lib"

	local package_name
	package_name=$(basename "$pkgnamedir")

	parse_depends
	parse_dump_object
	parse_shared_res
	gen_provides

	get_dummy_suffixes
	gen_march_symlinks

	local dummy_lib="$pkgdirprefix/lib/$dummy_lib_name"
	if [[ ! -f "$dummy_lib" ]]; then
		echo 'void dummy(void){}' | ${CC:-gcc} -shared -xc - -o "$dummy_lib"
	fi

	write_linker_config
}
